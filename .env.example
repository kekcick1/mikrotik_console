# Copy to .env and set values before docker compose up
# cp .env.example .env

# Required: must be a valid Fernet key (url-safe base64)
# Generate:
# python3 -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
MIM_SECRET=REPLACE_WITH_FERNET_KEY

# Optional
MIM_ADMIN_PASSWORD=admin
MIM_PORT=8080
DATA_DIR=/data

# Needed only for Traefik mode
TRAEFIK_DOMAIN=example.com
