# Copy to .env and set values before docker compose up
# cp .env.example .env

# Required: must be a valid Fernet key (url-safe base64)
# Generate:
# python3 -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
MIM_SECRET=REPLACE_WITH_FERNET_KEY

# Optional but recommended: separate token-signing secret from Fernet encryption key.
# Any long random string works.
MIM_AUTH_SECRET=

# Optional
MIM_ADMIN_PASSWORD=admin
MIM_PORT=8080
DATA_DIR=/data

# Optional: comma-separated list of allowed browser origins for cross-origin API use.
# Leave empty for same-origin deployments behind the built-in UI.
# Example: https://mikrotik-console.example.com,https://admin.example.com
MIM_CORS_ORIGINS=

# Needed only for Traefik mode
TRAEFIK_DOMAIN=example.com

# Background health worker (server-side checks independent from browser tabs)
MIM_HEALTH_WORKER_ENABLED=1
MIM_HEALTH_WORKER_INTERVAL_SECONDS=45
MIM_HEALTH_WORKER_COMMAND=/system identity print without-paging

# Health status thresholds
MIM_HEALTH_STALE_SECONDS=120
MIM_HEALTH_HIGH_QUEUE_DEPTH=3

# Alerts
MIM_ALERT_COOLDOWN_SECONDS=300
MIM_ALERT_REPEAT_WHILE_DOWN=0
MIM_ALERT_HISTORY_MAX=500
# Optional webhook receiver for alert notifications (POST JSON)
MIM_ALERT_WEBHOOK_URL=
